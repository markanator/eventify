{
	"plugins": ["react", "typescript", "jest"],
	"categories": {
		"correctness": "warn"
	},
	"rules": {
		"react/react-in-jsx-scope": "off"
	},
	"settings": {
		"react": {
			"formComponents": [],
			"linkComponents": [],
			"version": "19",
			"componentWrapperFunctions": []
		},
		"vitest": {
			"typecheck": false
		}
	},
	"ignorePatterns": ["node_modules", "build", "dist", "public/build"]
}
